<UserControl x:Class="RockyMuhasebe.Presentation.Views.ChartOfAccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <DockPanel Margin="20">
        <!-- Araç Çubuğu -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CardPanel}" Padding="15,10" Margin="8,0,8,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Yeni Hesap" Style="{StaticResource PrimaryButton}" Padding="16,8"/>
                <Button Content="✏️ Düzenle" Style="{StaticResource SecondaryButton}" Padding="16,8"/>
                <Button Content="🗑️ Sil" Style="{StaticResource DangerButton}" Padding="16,8"/>
                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="10,4"/>
                <Button Content="🔄 Yenile" Style="{StaticResource SecondaryButton}" Padding="16,8" Command="{Binding RefreshCommand}"/>
                <Button Content="📤 Excel" Style="{StaticResource SecondaryButton}" Padding="16,8"/>
                <Button Content="🖨️ Yazdır" Style="{StaticResource SecondaryButton}" Padding="16,8"/>
                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="10,4"/>
                <Border CornerRadius="6" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Width="250" Margin="4" Padding="10,8">
                    <Grid>
                        <TextBlock Text="🔍 Hesap kodu veya adı ara..." Foreground="#BDC3C7" VerticalAlignment="Center" FontSize="12" IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Hesap Planı Tablosu -->
        <Border Style="{StaticResource CardPanel}" Margin="8,0">
            <DataGrid ItemsSource="{Binding Accounts}" 
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                      RowStyle="{StaticResource ModernDataGridRow}"
                      CellStyle="{StaticResource ModernDataGridCell}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Hesap Kodu" Binding="{Binding Code}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Hesap Adı" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Hesap Türü" Binding="{Binding Type}" Width="120"/>
                    <DataGridTextColumn Header="Bakiye" Binding="{Binding Balance}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
